.instagram-section{
    padding:70px 8%;
    background:#fff;
}

.instagram-section h2{
    text-align:center;
    margin-bottom:40px;
    font-size:38px;
}

.instagram-profile{
    display:flex;
    align-items:center;
    gap:30px;
    margin-bottom:40px;
}

.instagram-profile img{
    width:120px;
    height:120px;
    border-radius:50%;
    object-fit:cover;
}

.instagram-profile h3{
    margin-bottom:10px;
}

.instagram-profile a{
    display:inline-block;
    margin-top:15px;
    padding:12px 25px;
    background:#E1306C;
    color:white;
    text-decoration:none;
    border-radius:5px;
}

.instagram-gallery{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:20px;
}

.instagram-gallery img{
    width:100%;
    height:320px;
    object-fit:cover;
    transition:.4s;
    cursor:pointer;
}

.instagram-gallery img:hover{
    transform:scale(1.05);
}